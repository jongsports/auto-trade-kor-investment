# ==========================================
# 민감한 인증 정보 (Secrets)
# 이 파일은 절대 GitHub 등 버전 관리 시스템에 커밋하지 마세요!
# 설정(파라미터 등)은 config_dir/config.yaml에서 수행합니다.
# ==========================================

# 한국투자증권 API 통신을 위한 필수 키 (필수입력)
APP_KEY="여기에_APP_KEY를_입력하세요"
APP_SECRET="여기에_APP_SECRET을_입력하세요"
ACCOUNT_NUMBER="여기에_계좌번호를_입력하세요"

# OpenDART 공시 정보 조회 API 키 (선택사항)
DART_API_KEY=""

# ==========================================
# 알림 시스템 인증 정보 (Secrets)
# ==========================================

# Telegram 채널 알림
TELEGRAM_TOKEN="여기에_봇_토큰을_입력하세요"
TELEGRAM_CHAT_ID="여기에_채널아이디를_입력하세요"

# Email 알림 수/발신 설정
EMAIL_SMTP_SERVER=""
EMAIL_SENDER=""
EMAIL_PASSWORD=""
EMAIL_RECIPIENTS=""
